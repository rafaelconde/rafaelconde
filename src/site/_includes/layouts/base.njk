<!doctype html>
<html class="no-js" lang="en" data-asset-version="{{ build.assetVersion }}">
  <head>
    <meta charset="utf-8" />
    <title>{%- if title -%}{{ title }}{%- else -%}Rafa's website{%- endif -%}</title>
    <meta name="description" content="{%- if description -%}{{ description }}{%- else -%}Personal website of Rafael Conde{%- endif -%}">
    <meta name="author" content="Rafael Conde">
    <meta name="viewport" content="initial-scale=1.0" />
    <meta name="theme-color" content="rgb(255 255 255)">
    <link rel="icon" href="favicon.ico" type="image/x-icon" />
    {% if stylesheet %}
    <link rel="stylesheet" href="/css/{{ stylesheet }}?v={{ build.assetVersion }}"/>
    {% else %}
    <link rel="stylesheet" href="/css/styles.css?v={{ build.assetVersion }}"/>
    {% endif %}
  </head>
  <body>
    {{ content | safe }}
    <script defer src="/js/scripts.js?v={{ build.assetVersion }}"></script>
  </body>
</html>
